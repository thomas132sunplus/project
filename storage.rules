rules_version = '2';

// Firebase Storage 安全規則
service firebase.storage {
  match /b/{bucket}/o {
    
    // 練習賽相關文件
    match /practice_matches/{matchId}/{allPaths=**} {
      // 任何登入用戶都可以讀取
      allow read: if request.auth != null;
      // 任何登入用戶都可以上傳
      allow write: if request.auth != null;
    }
    
    // 默認規則：需要認證
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
