rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(currentUserPath())
        && get(currentUserPath()).data.role == 'admin';
    }

    function teamPath(teamId) {
      return /databases/$(database)/documents/teams/$(teamId);
    }

    function isTeamMember(teamId) {
      return signedIn()
        && teamId is string
        && exists(teamPath(teamId))
        && request.auth.uid in get(teamPath(teamId)).data.members;
    }

    function invitationParticipant(data) {
      return signedIn()
        && (
          (data.fromTeam is string && isTeamMember(data.fromTeam))
          || (data.toTeam is string && isTeamMember(data.toTeam))
        );
    }

    function matchParticipant(data) {
      return signedIn()
        && (
          (data.createdBy is string && data.createdBy == request.auth.uid)
          || (data.affirmativeTeam is string && isTeamMember(data.affirmativeTeam))
          || (data.negativeTeam is string && isTeamMember(data.negativeTeam))
        );
    }

    function matchPath(matchId) {
      return /databases/$(database)/documents/practice_matches/$(matchId);
    }

    function canAccessMatchById(matchId) {
      return signedIn()
        && matchId is string
        && exists(matchPath(matchId))
        && matchParticipant(get(matchPath(matchId)).data);
    }

    match /users/{userId} {
      allow get: if signedIn();
      allow list: if isAdmin();
      // create: 只能建立自己的文件，role 必須是 'debater'，不得含測試標記欄位
      allow create: if isSelf(userId)
                    && request.resource.data.role == 'debater'
                    && !('_pentestMarker' in request.resource.data.keys());
      // update: 只能改自己的文件，role 與 email 不得變動；admin 可改他人但同樣不能改 role
      allow update: if (isSelf(userId)
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.email == resource.data.email)
                    || (isAdmin()
                        && request.resource.data.role == resource.data.role);
      allow delete: if false;
    }

    match /teams/{teamId} {
      allow read: if (signedIn() && request.auth.uid in resource.data.members) || isAdmin();
      // create: 建立者必須在 members 裡面
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.members;
      // update: 隊長可改所有欄位；成員只能改 members（加入/離開）
      allow update: if isAdmin()
        || (signedIn() && request.auth.uid == resource.data.captain)
        || (signedIn() && request.auth.uid in resource.data.members
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']));
      // delete: 只有隊長或 admin 可刪除
      allow delete: if (signedIn() && request.auth.uid == resource.data.captain) || isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if signedIn();
      // create: 必須設定 createdBy 為自己
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || isAdmin()
        );
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      // create: 必須設定 createdBy 為自己
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || isAdmin()
        );
    }

    match /invitations/{invitationId} {
      allow read: if invitationParticipant(resource.data) || isAdmin();
      allow create: if invitationParticipant(request.resource.data) || isAdmin();
      allow update, delete: if invitationParticipant(resource.data) || isAdmin();
    }

    match /practice_matches/{matchId} {
      allow read: if matchParticipant(resource.data) || isAdmin();
      allow create: if matchParticipant(request.resource.data) || isAdmin();
      allow update, delete: if matchParticipant(resource.data) || isAdmin();

      match /recordings/{recordingId} {
        allow read, create, update, delete: if canAccessMatchById(matchId) || isAdmin();
      }
    }

    // practiceMatches（舊集合）：收緊為 createdBy 擁有者或參與者才可讀取
    match /practiceMatches/{matchId} {
      allow read: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || (resource.data.affirmativeTeam is string && isTeamMember(resource.data.affirmativeTeam))
          || (resource.data.negativeTeam is string && isTeamMember(resource.data.negativeTeam))
          || isAdmin()
        );
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || isAdmin()
        );

      match /messages/{messageId} {
        allow read: if signedIn()
          && (
            get(/databases/$(database)/documents/practiceMatches/$(matchId)).data.createdBy == request.auth.uid
            || isAdmin()
          );
        allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if signedIn()
          && (
            resource.data.authorId == request.auth.uid
            || isAdmin()
          );
      }
    }

    match /practice_match_messages/{messageId} {
      allow read: if canAccessMatchById(resource.data.matchId) || isAdmin();
      allow create: if canAccessMatchById(request.resource.data.matchId)
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
    }

    match /practice_match_files/{fileId} {
      allow read: if canAccessMatchById(resource.data.matchId) || isAdmin();
      allow create: if canAccessMatchById(request.resource.data.matchId)
        && request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.uploaderId == request.auth.uid
          || isAdmin()
        );
    }

    match /practice_match_recordings/{recordingId} {
      allow read: if canAccessMatchById(resource.data.matchId) || isAdmin();
      allow create: if canAccessMatchById(request.resource.data.matchId)
        && request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.uploaderId == request.auth.uid
          || isAdmin()
        );
    }

    match /practice_match_calls/{callId} {
      allow read: if canAccessMatchById(resource.data.matchId) || isAdmin();
      allow create: if canAccessMatchById(request.resource.data.matchId)
        && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.creatorId == request.auth.uid
          || isAdmin()
        );
    }

    match /team_messages/{messageId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
      allow update: if false;
    }

    match /team_files/{fileId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.uploadedBy == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.uploadedBy == request.auth.uid
          || isAdmin()
        );
    }

    match /team_recordings/{recordingId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.uploadedBy == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.uploadedBy == request.auth.uid
          || isAdmin()
        );
    }

    match /team_calls/{callId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.creatorId == request.auth.uid
          || isAdmin()
        );
    }

    match /team_events/{eventId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if signedIn()
        && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /team_availability/{availabilityId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
      // create: 限制欄位白名單、合法通知類型、isRead 必須 false、createdAt 必須 server timestamp
      allow create: if signedIn()
        && request.resource.data.userId is string
        && request.resource.data.keys().hasOnly(
             ['userId', 'type', 'title', 'message', 'relatedId', 'linkTo', 'metadata', 'isRead', 'createdAt'])
        && request.resource.data.type in [
             'chat_message', 'tournament_update', 'meeting_start', 'meeting_reminder',
             'practice_invitation', 'invitation_response', 'calendar_event',
             'file_upload', 'recording_upload', 'feedback',
             'match_cancel_request', 'match_cancelled', 'team_member_added', 'announcement']
        && request.resource.data.isRead == false
        && request.resource.data.createdAt == request.time
        && (!('linkTo' in request.resource.data) || request.resource.data.linkTo == null || request.resource.data.linkTo.matches('^/.*'));
    }

    match /personal_events/{eventId} {
      allow read, update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
      allow create: if signedIn()
        && (
          request.resource.data.userId == request.auth.uid
          || isAdmin()
        );
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /guide_topics/{topicId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // 邀請碼：只允許按 ID 取得單一文件（防枚舉），不允許 list 查詢
    match /invite_codes/{codeId} {
      allow get: if true;
      allow list: if false;
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount'])
        && request.resource.data.usageCount == resource.data.usageCount + 1;
      allow create, delete: if isAdmin();
    }

    match /messages/{messageId} {
      // read: 只能讀取自己的訊息或 admin
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
      // create: 只能以自己的身份發送
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      // update/delete: 只能改自己的訊息或 admin
      allow update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
    }

    match /voice_rooms/{roomId} {
      allow read: if signedIn();
      // create: 必須記錄建立者為自己
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      // update: 房間建立者或現有參與者可更新；delete: 只有建立者或 admin
      allow update: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || request.auth.uid in resource.data.participants
          || isAdmin()
        );
      allow delete: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || isAdmin()
        );

      match /offers/{offerId} {
        allow read, write: if signedIn()
          && (
            request.auth.uid in get(/databases/$(database)/documents/voice_rooms/$(roomId)).data.participants
            || get(/databases/$(database)/documents/voice_rooms/$(roomId)).data.createdBy == request.auth.uid
          );
      }

      match /answers/{answerId} {
        allow read, write: if signedIn()
          && (
            request.auth.uid in get(/databases/$(database)/documents/voice_rooms/$(roomId)).data.participants
            || get(/databases/$(database)/documents/voice_rooms/$(roomId)).data.createdBy == request.auth.uid
          );
      }

      match /ice_candidates/{candidateId} {
        allow read, write: if signedIn()
          && (
            request.auth.uid in get(/databases/$(database)/documents/voice_rooms/$(roomId)).data.participants
            || get(/databases/$(database)/documents/voice_rooms/$(roomId)).data.createdBy == request.auth.uid
          );
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
