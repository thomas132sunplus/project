rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(currentUserPath())
        && get(currentUserPath()).data.role == 'admin';
    }

    function teamPath(teamId) {
      return /databases/$(database)/documents/teams/$(teamId);
    }

    function isTeamMember(teamId) {
      return signedIn()
        && teamId is string
        && exists(teamPath(teamId))
        && request.auth.uid in get(teamPath(teamId)).data.members;
    }

    function invitationParticipant(data) {
      return signedIn()
        && (
          (data.fromTeam is string && isTeamMember(data.fromTeam))
          || (data.toTeam is string && isTeamMember(data.toTeam))
        );
    }

    function matchParticipant(data) {
      return signedIn()
        && (
          (data.createdBy is string && data.createdBy == request.auth.uid)
          || (data.affirmativeTeam is string && isTeamMember(data.affirmativeTeam))
          || (data.negativeTeam is string && isTeamMember(data.negativeTeam))
        );
    }

    function matchPath(matchId) {
      return /databases/$(database)/documents/practice_matches/$(matchId);
    }

    function canAccessMatchById(matchId) {
      return signedIn()
        && matchId is string
        && exists(matchPath(matchId))
        && matchParticipant(get(matchPath(matchId)).data);
    }

    match /users/{userId} {
      allow read: if signedIn();
      // create: 只能建立自己的文件，role 必須是 'debater'，不得含測試標記欄位
      allow create: if isSelf(userId)
                    && request.resource.data.role == 'debater'
                    && !('_pentestMarker' in request.resource.data.keys());
      // update: 只能改自己的文件，role 與 email 不得變動；admin 可改他人但同樣不能改 role
      allow update: if (isSelf(userId)
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.email == resource.data.email)
                    || (isAdmin()
                        && request.resource.data.role == resource.data.role);
      allow delete: if false;
    }

    match /teams/{teamId} {
      allow read: if (signedIn() && request.auth.uid in resource.data.members) || isAdmin();
      allow create: if signedIn();
      allow update, delete: if (signedIn() && request.auth.uid in resource.data.members) || isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || isAdmin()
        );
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn()
        && (
          !('createdBy' in resource.data)
          || resource.data.createdBy == request.auth.uid
          || isAdmin()
        );
    }

    match /invitations/{invitationId} {
      allow read: if invitationParticipant(resource.data) || isAdmin();
      allow create: if invitationParticipant(request.resource.data) || isAdmin();
      allow update, delete: if invitationParticipant(resource.data) || isAdmin();
    }

    match /practice_matches/{matchId} {
      allow read: if matchParticipant(resource.data) || isAdmin();
      allow create: if matchParticipant(request.resource.data) || isAdmin();
      allow update, delete: if matchParticipant(resource.data) || isAdmin();

      match /recordings/{recordingId} {
        allow read, create, update, delete: if canAccessMatchById(matchId) || isAdmin();
      }
    }

    match /practiceMatches/{matchId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || isAdmin()
        );

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if signedIn()
          && (
            resource.data.authorId == request.auth.uid
            || isAdmin()
          );
      }
    }

    match /practice_match_messages/{messageId} {
      allow read: if canAccessMatchById(resource.data.matchId) || isAdmin();
      allow create: if canAccessMatchById(request.resource.data.matchId)
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
    }

    match /practice_match_files/{fileId} {
      allow read: if canAccessMatchById(resource.data.matchId) || isAdmin();
      allow create: if canAccessMatchById(request.resource.data.matchId)
        && request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.uploaderId == request.auth.uid
          || isAdmin()
        );
    }

    match /practice_match_recordings/{recordingId} {
      allow read: if canAccessMatchById(resource.data.matchId) || isAdmin();
      allow create: if canAccessMatchById(request.resource.data.matchId)
        && request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.uploaderId == request.auth.uid
          || isAdmin()
        );
    }

    match /practice_match_calls/{callId} {
      allow read: if canAccessMatchById(resource.data.matchId) || isAdmin();
      allow create: if canAccessMatchById(request.resource.data.matchId)
        && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.creatorId == request.auth.uid
          || isAdmin()
        );
    }

    match /team_messages/{messageId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
      allow update: if false;
    }

    match /team_files/{fileId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.uploadedBy == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.uploadedBy == request.auth.uid
          || isAdmin()
        );
    }

    match /team_recordings/{recordingId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.uploadedBy == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.uploadedBy == request.auth.uid
          || isAdmin()
        );
    }

    match /team_calls/{callId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.creatorId == request.auth.uid
          || isAdmin()
        );
    }

    match /team_events/{eventId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isTeamMember(resource.data.teamId) || isAdmin();
    }

    match /team_availability/{availabilityId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId)
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
      allow create: if signedIn();
    }

    match /personal_events/{eventId} {
      allow read, update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );
      allow create: if signedIn()
        && (
          request.resource.data.userId == request.auth.uid
          || isAdmin()
        );
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /guide_topics/{topicId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read, create, update, delete: if signedIn();
    }

    match /voice_rooms/{roomId} {
      allow read, create, update, delete: if signedIn();

      match /offers/{offerId} {
        allow read, write: if signedIn();
      }

      match /answers/{answerId} {
        allow read, write: if signedIn();
      }

      match /ice_candidates/{candidateId} {
        allow read, write: if signedIn();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
